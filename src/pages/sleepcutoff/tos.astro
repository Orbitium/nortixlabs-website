---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.jsx';
import Footer from '../../components/Footer.jsx';
import SleepCutoffTermsOfService from '../../components/SleepCutoffTermsOfService.astro';
---

<Layout title="Sleep Cutoff Terms of Service | Nortixlabs">
  <Navbar client:load />

  <main class="pt-32 pb-24 relative z-10 min-h-screen">
    <div class="container mx-auto px-6 max-w-4xl">
      <div class="glass p-8 md:p-12 rounded-2xl border border-white/5">
        <header class="mb-8 pb-6 border-b border-white/5">
          <p class="text-sm uppercase tracking-[0.22em] text-cyan-400/80 mb-3">Sleep Cutoff</p>
          <h1 class="text-3xl md:text-4xl font-bold font-display text-white mb-4">Terms of Service</h1>
          <p class="text-slate-400">Rendered from the provided Sleep Cutoff terms draft.</p>
        </header>

        <SleepCutoffTermsOfService />
      </div>
    </div>
  </main>

  <Footer client:visible />
</Layout>
