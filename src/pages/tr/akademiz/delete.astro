---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.jsx';
import Footer from '../../../components/Footer.jsx';
import { Resend } from 'resend';

export const prerender = false;

let success = false;
let error = null;
let isLoading = false;

if (Astro.request.method === 'POST') {
    isLoading = true;
    try {
        const formData = await Astro.request.formData();
        const email = formData.get('email')?.toString();

        if (!email) {
            error = "Lütfen bir e-posta adresi giriniz.";
        } else {
            const resendKey = import.meta.env.RESEND_API_KEY || Astro.locals.runtime?.env?.RESEND_API_KEY;
            const resend = new Resend(resendKey);

            const { data, error: resendError } = await resend.emails.send({
                from: 'Akademiz <onboarding@resend.dev>',
                to: [email],
                subject: 'AkademiZ Hesabınız Silindi',
                html: `
                    <div style="font-family: 'Inter', sans-serif; max-width: 600px; margin: 0 auto; padding: 40px; background-color: #f8fafc; border-radius: 24px; color: #1e293b;">
                        <div style="text-align: center; margin-bottom: 30px;">
                            <h1 style="color: #0ea5e9; font-size: 32px; font-weight: 800; margin: 0;">AkademiZ</h1>
                            <p style="color: #64748b; font-size: 14px;">Üniversite Haber & Etkinlik</p>
                        </div>
                        <div style="background-color: #ffffff; padding: 30px; border-radius: 16px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
                            <h2 style="color: #0f172a; margin-top: 0;">Hesap Başarıyla Silindi</h2>
                            <p>Merhaba,</p>
                            <p><strong>${email}</strong> adresiyle ilişkili <strong>AkademiZ</strong> hesabınızın başarıyla silindiğini onaylamak için yazıyoruz.</p>
                            <p><strong>Neler silindi?</strong></p>
                            <ul style="color: #475569; padding-left: 20px;">
                                <li>Kişisel profiliniz ve ayarlarınız</li>
                                <li>Kaydedilen haberler ve etkinlik LCV yanıtlarınız</li>
                                <li>Bildirim tercihleriniz ve geçmişiniz</li>
                            </ul>
                            <p style="margin-top: 20px; color: #ef4444; font-size: 14px; font-weight: 600;">
                                Not: Bu işlem kalıcıdır ve geri alınamaz.
                            </p>
                        </div>
                        <div style="text-align: center; margin-top: 30px; color: #94a3b8; font-size: 12px;">
                            <p>&copy; ${new Date().getFullYear()} NortixLabs. Tüm hakları saklıdır.</p>
                            <p>Bu otomatik bir onay e-postasıdır.</p>
                        </div>
                    </div>
                `
            });

            if (resendError) {
                console.error("Resend hatası:", resendError);
                error = "Hesap silme talebi alındı, ancak onay e-postası gönderilemedi.";
            } else {
                success = true;
            }
        }
    } catch (e) {
        console.error("Silme hatası:", e);
        error = "Hesap silme işlemi sırasında beklenmedik bir hata oluştu.";
    } finally {
        isLoading = false;
    }
}
---

<Layout title="Hesabımı Sil | AkademiZ" lang="tr">
	<Navbar client:load lang="tr" />

	<main class="relative min-h-screen pt-32 pb-20 overflow-hidden bg-[#020617]">
        <!-- Background Decorations -->
        <div class="absolute top-0 left-0 w-full h-full -z-10">
            <div class="absolute top-1/4 -left-20 w-96 h-96 bg-red-600/10 blur-[120px] rounded-full"></div>
            <div class="absolute bottom-1/4 -right-20 w-96 h-96 bg-orange-600/10 blur-[120px] rounded-full"></div>
        </div>

		<div class="container mx-auto px-6 relative">
			<div class="max-w-xl mx-auto">
                <div class="glass-card p-8 md:p-12 rounded-[2.5rem] border border-white/10 relative overflow-hidden backdrop-blur-2xl shadow-2xl">
                    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-red-500 via-orange-500 to-red-500 animate-gradient-x"></div>
                    
                    {success ? (
                        <div class="text-center py-8 animate-in fade-in zoom-in duration-500">
                            <div class="w-24 h-24 bg-emerald-500/10 border border-emerald-500/20 rounded-full flex items-center justify-center mx-auto mb-8 shadow-lg shadow-emerald-500/10">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                </svg>
                            </div>
                            <h2 class="text-3xl font-bold mb-4 text-white">Hesap Silindi</h2>
                            <p class="text-slate-400 mb-10 leading-relaxed px-4">
                                Hesabınız kalıcı olarak silinmiştir. E-posta adresinize bir onay mesajı gönderildi.
                            </p>
                            <a href="/tr/akademiz" class="inline-flex items-center justify-center px-10 py-4 bg-white text-slate-950 rounded-xl font-bold hover:bg-slate-200 transition-all duration-300 shadow-xl hover:scale-105 active:scale-95">
                                AkademiZ'e Dön
                            </a>
                        </div>
                    ) : (
                        <>
                            <div class="mb-10 text-center">
                                <h1 class="text-3xl md:text-5xl font-bold mb-4 bg-clip-text text-transparent bg-gradient-to-r from-red-400 to-orange-400">
                                    Hesap Silme
                                </h1>
                                <p class="text-slate-400">Gittiğiniz için üzgünüz.</p>
                            </div>
                            
                            <div class="space-y-6 text-slate-300 mb-10 text-sm md:text-base">
                                <section class="bg-white/5 border border-white/10 rounded-2xl p-6">
                                    <h3 class="text-white font-bold mb-3 flex items-center gap-2">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                        </svg>
                                        Nasıl çalışır?
                                    </h3>
                                    <p class="text-slate-400 leading-relaxed">
                                        E-postanızı gönderdiğinizde, sistemimiz hesabınızı tanımlayacak ve onunla ilişkili tüm verileri sunucularımızdan kalıcı olarak silecektir. Bu işlem profilinizi, etkinlik geçmişinizi ve tercihlerinizi içerir.
                                    </p>
                                </section>

                                <div class="bg-red-500/10 border border-red-500/20 rounded-2xl p-6">
                                    <h3 class="text-red-400 font-bold mb-3 flex items-center gap-2">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                                        </svg>
                                        Kritik Bilgi
                                    </h3>
                                    <ul class="space-y-2 text-red-300/80">
                                        <li class="flex items-start gap-2">
                                            <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-red-400 shrink-0"></span>
                                            Silme işlemi <strong>kalıcıdır</strong> ve geri alınamaz.
                                        </li>
                                        <li class="flex items-start gap-2">
                                            <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-red-400 shrink-0"></span>
                                            Tüm veriler GDPR/KVKK politikalarına uygun olarak temizlenecektir.
                                        </li>
                                        <li class="flex items-start gap-2">
                                            <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-red-400 shrink-0"></span>
                                            Tüm beta özelliklerine erişiminizi kaybedeceksiniz.
                                        </li>
                                    </ul>
                                </div>
                            </div>

                            <form method="POST" class="space-y-6">
                                {error && (
                                    <div class="p-4 bg-red-500/10 border border-red-500/20 rounded-xl text-red-400 text-sm flex items-center gap-3 animate-shake">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                        </svg>
                                        {error}
                                    </div>
                                )}
                                
                                <div class="space-y-2 group">
                                    <label for="email" class="text-sm font-medium text-slate-400 group-focus-within:text-red-400 transition-colors">Hesap e-postanızı girin</label>
                                    <input 
                                        type="email" 
                                        id="email" 
                                        name="email" 
                                        required 
                                        placeholder="ogrenci@omu.edu.tr"
                                        class="w-full bg-slate-950/50 border border-white/10 rounded-xl px-5 py-4 focus:outline-none focus:border-red-500/50 transition-all text-white placeholder:text-slate-600 block"
                                    />
                                </div>

                                <div class="flex items-start gap-3 p-4 bg-white/5 rounded-2xl cursor-pointer hover:bg-white/10 transition-colors group">
                                    <input type="checkbox" id="confirm" required class="mt-1 w-5 h-5 accent-red-600 cursor-pointer" />
                                    <label for="confirm" class="text-sm text-slate-400 cursor-pointer group-hover:text-slate-300 transition-colors">
                                        Hesabımı ve tüm ilişkili verilerimi kalıcı olarak silmek istediğimi onaylıyorum.
                                    </label>
                                </div>

                                <button 
                                    type="submit" 
                                    id="submit-btn"
                                    class="w-full py-4 bg-red-600 hover:bg-red-500 text-white font-bold rounded-xl transition-all duration-300 shadow-xl shadow-red-900/40 hover:scale-[1.02] active:scale-[0.98] flex items-center justify-center gap-3 group"
                                >
                                    <span>Hesabımı Sil</span>
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                    </svg>
                                </button>
                            </form>
                        </>
                    )}
                </div>
			</div>
		</div>
	</main>

	<Footer client:visible lang="tr" />
</Layout>

<style>
    .glass-card {
        background: rgba(15, 23, 42, 0.4);
        backdrop-filter: blur(24px);
    }
    
    @keyframes gradient-x {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
    }
    
    .animate-gradient-x {
        background-size: 200% 200%;
        animation: gradient-x 3s ease infinite;
    }

    @keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-5px); }
        75% { transform: translateX(5px); }
    }

    .animate-shake {
        animation: shake 0.2s ease-in-out 0s 2;
    }
</style>

<script>
    const form = document.querySelector('form');
    const submitBtn = document.getElementById('submit-btn');

    if (form && submitBtn) {
        form.addEventListener('submit', () => {
            submitBtn.innerHTML = `
                <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <span>Hesap Siliniyor...</span>
            `;
            submitBtn.disabled = true;
            submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
        });
    }
</script>
