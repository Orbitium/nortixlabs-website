---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.jsx';
import Footer from '../../components/Footer.jsx';

interface Props {
    lang: 'en' | 'tr';
}

const { lang = 'en' } = Astro.props;

const newsImages = [
    '/akademiz/news.png',
    '/akademiz/news_2.png'
];

const eventsImages = [
    '/akademiz/events.png',
    '/akademiz/events_2.png'
];

const content = {
    en: {
        title: "AkademiZ - University News & Events App | NortixLabs",
        heroTitle: "AkademiZ",
        heroDesc: "Your ultimate companion for university life. Stay connected, informed, and ahead of the curve with our comprehensive news and events application.",
        feature1Title: "Stay in the Loop",
        feature1Desc: "Never miss an important announcement again. Our real-time news feed aggregates updates from all university departments, student clubs, and administrative bodies into one seamless scrolling experience.",
        feature1Point1: "Instant push notifications for urgent alerts",
        feature1Point2: "Personalized content based on your major",
        feature1Point3: "Bookmark articles for later reading",
        feature2Title: "Discover & Attend",
        feature2Desc: "Find out what's happening on campus with our interactive events calendar. From guest lectures to social gatherings, get all the details, RSVP with a single tap, and add events directly to your personal schedule.",
        feature2Point1: "Interactive campus map integration",
        feature2Point2: "One-click calendar sync (Google/Outlook)",
        feature2Point3: "Filter events by club or department",
        feature3Title: "Get Notified Instantly",
        feature3Desc: "Stay ahead of campus life with our powerful notification system. From urgent schedule changes to upcoming events and club announcements, information finds you exactly when it matters.",
        feature3Point1: "Urgent administrative alerts",
        feature3Point2: "Personalized major-related updates",
        feature3Point3: "Event start reminders & reminders",
        ctaTitle: "Experience AkademiZ Early",
        ctaDesc: "We're currently in <span class='text-cyan-400 font-semibold'>Closed Beta</span>. Join our exclusive group of beta testers and help shape the future of university communication.",
        playStore: "Coming Soon to",
        betaButton: "Become a Beta Tester",
        betaFooter: "Closed Beta slots available for OMU Students"
    },
    tr: {
        title: "AkademiZ - Üniversite Haber & Etkinlik Uygulaması | NortixLabs",
        heroTitle: "Akademiz",
        heroDesc: "Üniversite hayatı için mükemmel arkadaşınız. Kapsamlı haber ve etkinlik uygulamamızla bağlantıda kalın, bilgilenin ve bir adım önde olun.",
        feature1Title: "Haberdar Kalın",
        feature1Desc: "Önemli bir duyuruyu bir daha asla kaçırmayın. Gerçek zamanlı haber akışımız; tüm üniversite bölümlerinden, öğrenci kulüplerinden ve idari birimlerden gelen güncellemeleri tek bir kusursuz deneyimde birleştirir.",
        feature1Point1: "Acil uyarılar için anlık bildirimler",
        feature1Point2: "Bölümünüze göre kişiselleştirilmiş içerik",
        feature1Point3: "Makaleleri daha sonra okumak için yer imlerine ekleyin",
        feature2Title: "Keşfet ve Katıl",
        feature2Desc: "İnteraktif etkinlik takvimimizle kampüste neler olup bittiğini öğrenin. Misafir derslerinden sosyal toplantılara kadar tüm detayları alın, tek bir dokunuşla LCV yanıtı verin ve etkinlikleri doğrudan kişisel takviminize ekleyin.",
        feature2Point1: "İnteraktif kampüs haritası entegrasyonu",
        feature2Point2: "Tek tıkla takvim senkronizasyonu (Google/Outlook)",
        feature2Point3: "Etkinlikleri kulübe veya bölüme göre filtreleyin",
        feature3Title: "Anında Bildirim Alın",
        feature3Desc: "Güçlü bildirim sistemimizle kampüs hayatının önünde kalın. Acil program değişikliklerinden yaklaşan etkinliklere ve kulüp duyurularına kadar, bilgi tam da önemli olduğu anda sizi bulur.",
        feature3Point1: "Acil idari uyarılar",
        feature3Point2: "Bölümle ilgili kişiselleştirilmiş güncellemeler",
        feature3Point3: "Etkinlik başlama hatırlatıcıları",
        ctaTitle: "AkademiZ'i Erken Deneyimleyin",
        ctaDesc: "Şu anda <span class='text-cyan-400 font-semibold'>Kapalı Beta</span> aşamasındayız. Özel beta test grubumuza katılın ve üniversite iletişiminin geleceğini şekillendirmeye yardımcı olun.",
        playStore: "Yakında Şurada",
        betaButton: "Beta Test Kullanıcısı Olun",
        betaFooter: "OMÜ Öğrencileri için Kapalı Beta kontenjanı mevcuttur"
    }
};

const t = content[lang] || content.en;
---

<Layout title={t.title} lang={lang}>
	<Navbar lang={lang} client:load />

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const setupCrossfade = (containerId) => {
                const container = document.getElementById(containerId);
                if (!container) return;

                const images = container.querySelectorAll('img');
                if (images.length < 2) return;

                let activeIndex = 0;
                
                setInterval(() => {
                    images[activeIndex].style.opacity = '0';
                    activeIndex = (activeIndex + 1) % images.length;
                    images[activeIndex].style.opacity = '1';
                }, 3000);
            };

            setupCrossfade('news-image-container');
            setupCrossfade('events-image-container');
        });
    </script>

	<section class="relative pt-24 md:pt-32 pb-16 md:pb-20 overflow-hidden">
		<div class="container mx-auto px-6">
			<div class="text-center max-w-4xl mx-auto mb-16 md:mb-24">
				<h1 class="text-3xl md:text-6xl font-bold mb-4 md:mb-6 bg-clip-text text-transparent bg-gradient-to-r from-violet-400 to-cyan-400">
					{t.heroTitle}
				</h1>
				<p class="text-lg md:text-xl text-slate-400 max-w-2xl mx-auto px-4">
					{t.heroDesc}
				</p>
			</div>

			<div class="space-y-20 md:space-y-32">
				<div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">
					<div class="w-full md:w-1/2">
						<div class="relative group transform hover:scale-[1.02] transition-all duration-500">
							<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[90%] h-[70%] bg-violet-600/30 blur-[60px] rounded-full -z-10 group-hover:bg-violet-500/40 transition-colors duration-1000"></div>
                            <div class="relative bg-slate-900 aspect-[9/20] w-[260px] md:w-[280px] mx-auto rounded-xl flex items-center justify-center border-4 border-black/50 shadow-2xl overflow-hidden" id="news-image-container">
                                {newsImages.map((src, index) => (
                                    <img 
                                        src={src} 
                                        alt={`Akademiz News Screenshot ${index + 1}`}
                                        loading={index === 0 ? "eager" : "lazy"}
                                        width="1080"
                                        height="2400"
                                        style={index === 0 ? "opacity: 1" : "opacity: 0"}
                                        class="absolute inset-0 w-full h-full object-cover transition-opacity duration-700" 
                                    />
                                ))}
							</div>
						</div>
					</div>
					<div class="w-full md:w-1/2 px-2 md:px-0">
						<div class="flex items-center gap-4 mb-4">
							<div class="p-2 rounded-lg bg-violet-500/10 border border-violet-500/20">
								<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 md:w-6 md:h-6 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
								</svg>
							</div>
							<h2 class="text-2xl md:text-3xl font-bold text-slate-100">{t.feature1Title}</h2>
						</div>
						<p class="text-base md:text-lg text-slate-400 leading-relaxed mb-6">
							{t.feature1Desc}
						</p>
						<ul class="space-y-3 text-sm md:text-base text-slate-300">
							<li class="flex items-center gap-3">
								<svg class="w-4 h-4 md:w-5 md:h-5 text-cyan-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
								{t.feature1Point1}
							</li>
							<li class="flex items-center gap-3">
								<svg class="w-4 h-4 md:w-5 md:h-5 text-cyan-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
								{t.feature1Point2}
							</li>
							<li class="flex items-center gap-3">
								<svg class="w-4 h-4 md:w-5 md:h-5 text-cyan-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
								{t.feature1Point3}
							</li>
						</ul>
					</div>
				</div>

				<div class="flex flex-col md:flex-row-reverse items-center gap-10 md:gap-16">
					<div class="w-full md:w-1/2">
						<div class="relative group transform hover:scale-[1.02] transition-all duration-500">
							<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[90%] h-[70%] bg-cyan-600/30 blur-[60px] rounded-full -z-10 group-hover:bg-cyan-500/40 transition-colors duration-1000"></div>
							<div class="relative bg-slate-900 aspect-[9/20] w-[260px] md:w-[280px] mx-auto rounded-xl flex items-center justify-center border-4 border-black/50 shadow-2xl overflow-hidden" id="events-image-container">
                                {eventsImages.map((src, index) => (
                                    <img 
                                        src={src} 
                                        alt={`Akademiz Events Screenshot ${index + 1}`}
                                        loading="lazy"
                                        width="1080"
                                        height="2400"
                                        style={index === 0 ? "opacity: 1" : "opacity: 0"}
                                        class="absolute inset-0 w-full h-full object-cover transition-opacity duration-700" 
                                    />
                                ))}
							</div>
						</div>
					</div>
					<div class="w-full md:w-1/2 px-2 md:px-0">
						<div class="flex items-center gap-4 mb-4">
							<div class="p-2 rounded-lg bg-cyan-500/10 border border-cyan-500/20">
								<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 md:w-6 md:h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
								</svg>
							</div>
							<h2 class="text-2xl md:text-3xl font-bold text-slate-100">{t.feature2Title}</h2>
						</div>
						<p class="text-base md:text-lg text-slate-400 leading-relaxed mb-6">
							{t.feature2Desc}
						</p>
						<ul class="space-y-3 text-sm md:text-base text-slate-300">
							<li class="flex items-center gap-3">
								<svg class="w-4 h-4 md:w-5 md:h-5 text-violet-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
								{t.feature2Point1}
							</li>
							<li class="flex items-center gap-3">
								<svg class="w-4 h-4 md:w-5 md:h-5 text-violet-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
								{t.feature2Point2}
							</li>
							<li class="flex items-center gap-3">
								<svg class="w-4 h-4 md:w-5 md:h-5 text-violet-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
								{t.feature2Point3}
							</li>
						</ul>
					</div>
				</div>

				<div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">
					<div class="w-full md:w-1/2">
						<div class="relative group transform hover:scale-[1.02] transition-all duration-500">
							<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[90%] h-[70%] bg-violet-600/30 blur-[60px] rounded-full -z-10 group-hover:bg-violet-500/40 transition-colors duration-1000"></div>
							<div class="relative bg-slate-900 aspect-[9/20] w-[260px] md:w-[280px] mx-auto rounded-xl flex items-center justify-center border-4 border-black/50 shadow-2xl overflow-hidden">
                                <img 
                                    src="/akademiz/notifications.png" 
                                    alt="Akademiz Social Features"
                                    loading="lazy"
                                    width="1080"
                                    height="2400"
                                    class="w-full h-full object-cover" 
                                />
							</div>
						</div>
					</div>
					<div class="w-full md:w-1/2 px-2 md:px-0">
						<div class="flex items-center gap-4 mb-4">
							<div class="p-2 rounded-lg bg-slate-700/50 border border-slate-600">
								<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 md:w-6 md:h-6 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
								</svg>
							</div>
							<h2 class="text-2xl md:text-3xl font-bold text-slate-100">{t.feature3Title}</h2>
						</div>
						<p class="text-base md:text-lg text-slate-400 leading-relaxed mb-6">
							{t.feature3Desc}
						</p>
						<ul class="space-y-3 text-sm md:text-base text-slate-300">
							<li class="flex items-center gap-3">
								<svg class="w-4 h-4 md:w-5 md:h-5 text-cyan-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
								{t.feature3Point1}
							</li>
							<li class="flex items-center gap-3">
								<svg class="w-4 h-4 md:w-5 md:h-5 text-cyan-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
								{t.feature3Point2}
							</li>
							<li class="flex items-center gap-3">
								<svg class="w-4 h-4 md:w-5 md:h-5 text-cyan-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
								{t.feature3Point3}
							</li>
						</ul>
					</div>
				</div>
			</div>

			<div class="mt-20 md:mt-32 relative">
				<div class="absolute inset-0 bg-gradient-to-r from-violet-600/20 to-cyan-600/20 blur-3xl rounded-full opacity-50 -z-10"></div>
				<div class="glass-card p-6 md:p-12 rounded-3xl md:rounded-[2.5rem] text-center border border-white/10 relative overflow-hidden group">
					<div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-violet-600 via-cyan-500 to-violet-600 animate-gradient-x"></div>
					
					<h2 class="text-2xl md:text-5xl font-bold text-white mb-4 md:mb-6">{t.ctaTitle}</h2>
					<p class="text-base md:text-xl text-slate-400 max-w-2xl mx-auto mb-8 md:mb-10 leading-relaxed px-4" set:html={t.ctaDesc}></p>

					<div class="flex flex-col sm:flex-row items-center justify-center gap-4 md:gap-6">
						<div class="relative group/btn w-full sm:w-auto">
							<div class="absolute -inset-1 bg-gradient-to-r from-cyan-600 to-violet-600 rounded-2xl blur opacity-25 group-hover/btn:opacity-75 transition duration-500"></div>
							<button class="relative w-full sm:w-auto px-6 md:px-8 py-3 md:py-4 bg-slate-950 rounded-xl border border-white/10 flex items-center justify-center gap-4 transition-all duration-300 hover:scale-105 opacity-50 cursor-not-allowed">
								<svg viewBox="0 0 24 24" class="w-6 h-6 md:w-8 md:h-8 fill-white" xmlns="http://www.w3.org/2000/svg">
									<path d="M3.609 1.814L13.792 12 3.61 22.186c-.18.18-.344.153-.464.03l-.01-.01c-.12-.12-.086-.334.076-.496l9.643-9.643L3.212 2.424c-.162-.162-.196-.376-.076-.496l.01-.01c.12-.123.284-.15.464.03v-.104zm11.233 9.133l2.844-2.844-3.665-2.115-3.085 4.959 3.906 3.906c.18.18.344.153.464.03l.01-.01c.12-.12.086-.334-.076-.496l-.5-.5zM17.441 8.163l3.66 2.112c.732.423.732 1.11 0 1.533l-2.607 1.505-1.053-1.053 2.844-2.844.01-.01c.12-.12.086-.334-.076-.496l-2.778-1.747z"/>
								</svg>
								<div class="text-left">
									<div class="text-[8px] md:text-[10px] uppercase font-bold text-slate-500">{t.playStore}</div>
									<div class="text-lg md:text-xl font-bold text-white">Google Play</div>
								</div>
							</button>
						</div>

						<a href={`${lang === 'en' ? '' : '/tr'}/#contact`} class="w-full sm:w-auto px-10 py-4 md:py-5 bg-white text-slate-950 rounded-xl font-bold hover:bg-cyan-400 hover:text-white transition-all duration-300 shadow-xl text-center">
							{t.betaButton}
						</a>
					</div>

					<div class="mt-8 flex items-center justify-center gap-2 text-slate-500 text-sm">
						<span class="w-2 h-2 rounded-full bg-cyan-500 animate-pulse"></span>
						{t.betaFooter}
					</div>
				</div>
			</div>
		</div>
	</section>
	<Footer lang={lang} client:visible />
</Layout>
